# ── Database ──────────────────────────────────────────────────────────────────
# MariaDB (Local): mysql://root:@localhost:3306/jmnews
# MySQL (XAMPP):   mysql://root:@localhost:3306/jmnews
# PostgreSQL:      postgresql://user:password@localhost:5432/jmnews
DATABASE_URL="mysql://root:@localhost:3306/jmnews"

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8000
APP_URL=http://localhost:8000

# ── Auth (REQUIRED — generate your own values) ────────────────────────────────
# IMPORTANT: Change these in production!
ADMIN_PASSWORD=change-me-to-a-strong-password-min-8-chars
STAFF_PASSWORD=change-me-to-another-strong-password-min-8-chars
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars-for-security

# ── WebSocket (Optional) ──────────────────────────────────────────────────────
WS_ENABLED=false
# WS_PORT=8001  # Optional: separate port for WebSocket (if not using same server)

# ── S3 Storage (Optional) ─────────────────────────────────────────────────────
S3_ENDPOINT=
S3_BUCKET=jm-news
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

